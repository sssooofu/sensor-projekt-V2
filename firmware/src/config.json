{
  "device_id": "pico_001",
  "fw_version": "1.0.0",

  "wifi": {
    "ssid": "abc",
    "password": "12345678",
    "timeout_s": 20
  },

  "server": {
    "url": "http://192.168.1.133:8080",
    "timeout_s": 10,
    "retry_count": 3,
    "retry_delay_s": 5
  },

  "poll_interval_s": 60,

  "sensors": {
    "ph":          { "enabled": false, "ads_channel": 0 },
    "ec":          { "enabled": false },
    "temperature": { "enabled": false },
    "humidity":    { "enabled": true },
    "light":       { "enabled": false },
    "soil":        { "enabled": true,  "adc_pin": 26 },
    "motion":      { "enabled": false, "scan_duration_s": 5 },
    "water_level": { "enabled": true,  "pin": 16 }
  },

  "calibration": {
    "ph": {
      "v_at_ph4": 1.855,
      "v_at_ph7": 1.650
    },
    "ec": {
      "cell_constant": 1.0,
      "ref_voltage": 1.65,
      "ref_temp_c": 25.0
    },
    "soil": {
      "dry_count": 65535,
      "wet_count": 9600
    }
  },

  "relay": {
    "max_on_duration_s": 600
  },

  "relay_schedule": [],

  "relay_rules": [
    { "sensor": "soil_pct", "op": ">=", "value": 60, "action": "relay_off" },
    { "sensor": "soil_pct", "op": "<",  "value": 30, "action": "relay_on", "duration_s": 300 }
  ],

  "storage": {
    "buffer_slots": 48
  }
}
